%% Figure 4 — Polyglot Import CSV configuration JSON Schemas (import + SGBD)
flowchart LR
    %% ===== Import (mapping) schema =====
    IRoot["import_config (root)<br/>version*, additionalProperties: false"]

    IRoot --> IPG["postgres"]
    IRoot --> IMG["mongodb"]
    IRoot --> ICA["cassandra"]
    IRoot --> IRD["redis"]
    IRoot --> INE["neo4j"]

    IPG --> PGent["entities*"]
    IPG --> PGrel["relationships<br/>from*, to*, foreign_key*,<br/>references_key"]
    IMG --> MGent["entities*"]
    ICA --> CAent["entities*"]
    IRD --> RDent["entities*"]
    INE --> NEent["entities*"]
    INE --> NErel["relationships<br/>from*, to*, type*,<br/>columns -> columnSpec"]

    PGent --> Entity
    MGent --> Entity
    CAent --> Entity
    RDent --> Entity
    NEent --> Entity

    subgraph EntityDef["entity (definição reutilizável)"]
      Entity["entity"]
      Entity --> Ecols["columns*<br/>(mapa recursivo)"]
      Entity --> Efilt["filters: [ filter ]"]
      Entity --> Epart["cassandra_partition: [string]"]
      Entity --> Eclus["cassandra_cluster: [string]"]
    end

    Ecols --> ColEntry{"columnEntry<br/>(oneOf)"}
    ColEntry --> Spec["columnSpec (folha)<br/>csv_column, schema_column,<br/>is_key, db_type"]
    ColEntry --> Branch["objeto aninhado<br/>(subdocumento MongoDB)<br/>-> columnEntry"]
    Branch -.recursivo.-> ColEntry

    Efilt --> Filter["filter<br/>column*, operator*,<br/>value, target_suffix"]

    %% ===== SGBD (connection) schema =====
    SRoot["sgbd_config (root)<br/>version*, additionalProperties: false"]
    SRoot --> SPG["postgres<br/>connection{host, port, database,<br/>user, password}, schema"]
    SRoot --> SMG["mongodb<br/>connection{uri*, database*}"]
    SRoot --> SCA["cassandra<br/>connection{hosts*, port,<br/>keyspace*, protocol_version}"]
    SRoot --> SRD["redis<br/>connection{host, port, db, password}"]
    SRoot --> SNE["neo4j<br/>connection{uri*, user*,<br/>password*, database}"]

    classDef req fill:#e8f0fe,stroke:#3b6ea5;
    classDef leaf fill:#eef7ee,stroke:#4a8f4a;
    classDef conn fill:#fdf3e7,stroke:#c08a3e;
    class IRoot,SRoot,Entity req;
    class Spec,Filter leaf;
    class SPG,SMG,SCA,SRD,SNE conn;
