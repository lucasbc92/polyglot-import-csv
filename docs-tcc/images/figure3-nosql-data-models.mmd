        direction LR
        K["chave"] --> V["valor<br/>(opaco ao SGBD)"]
    end

    subgraph COL["2. Colunar"]
        direction LR
        RK["chave de linha"] --> CF["famílias de colunas<br/>(pares nome-valor)"]
    end

    subgraph DOC["3. Documento"]
        direction LR
        ID["identificador"] --> BSON["documento<br/>JSON / BSON"]
